# ============================================================
# Database (Backend)
# ============================================================
POSTGRES_USER=fuelstation
POSTGRES_PASSWORD=fuelstation
POSTGRES_DB=fuelstation
DATABASE_URL=postgresql://fuelstation:fuelstation@postgres:5432/fuelstation

# ============================================================
# LiteLLM (AI Proxy)
# ============================================================
LITELLM_MASTER_KEY=sk-change-me
LITELLM_MODEL=glm-ocr
LITELLM_TIMEOUT=120.0
UI_USERNAME=admin
UI_PASSWORD=admin

# LiteLLM Database
LITELLM_DB_USER=litellm
LITELLM_DB_PASSWORD=litellm
LITELLM_DB_NAME=litellm
LITELLM_DATABASE_URL=postgresql://litellm:litellm@litellm-db:5432/litellm

# ============================================================
# YOLO Detection
# ============================================================
YOLO_MODEL_PATH=models/best.pt
YOLO_CONFIDENCE_THRESHOLD=0.25
MAX_IMAGE_SIZE_BYTES=10485760

# ============================================================
# OCR Confidence Thresholds
# ============================================================
HIGH_CONFIDENCE_THRESHOLD=0.9
MEDIUM_CONFIDENCE_THRESHOLD=0.6
LOW_CONFIDENCE_THRESHOLD=0.3
MAX_PLATE_LENGTH=12

# ============================================================
# Service Timeouts
# ============================================================
YOLO_TIMEOUT=30.0
OCR_TIMEOUT=120.0
FEED_INTERVAL=3
